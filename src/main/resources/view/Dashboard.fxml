<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.text.*?>

<ScrollPane fitToWidth="true" style="-fx-background-color: transparent;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1">
    <VBox spacing="25" style="-fx-padding: 30; -fx-background-color: #121212;">
        <Label text="BASKETBALL ANALYTICS HUB" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: white;" />
        
        <HBox spacing="20">
            <VBox prefWidth="250" styleClass="card" style="-fx-padding: 20;">
                <Label text="EFICIENTA E EKIPIT" style="-fx-text-fill: #888;" />
                <Label text="94.2%" style="-fx-font-size: 32; -fx-text-fill: #FF8C00; -fx-font-weight: bold;" />
                <Label text="+2.4% nga ndeshja e kaluar" style="-fx-text-fill: #00ff00; -fx-font-size: 12;" />
            </VBox>
            
            <VBox prefWidth="250" styleClass="card" style="-fx-padding: 20;">
                <Label text="PARASHIKIMI AI (Next Win)" style="-fx-text-fill: #888;" />
                <Label text="78% Probabilitet" style="-fx-font-size: 24; -fx-text-fill: #2196f3; -fx-font-weight: bold;" />
                <ProgressBar progress="0.78" prefWidth="200" />
            </VBox>
        </HBox>

        <HBox spacing="20">
            <LineChart title="Trendi i Pikëve (Sezoni 2026)" prefHeight="350">
                <xAxis><CategoryAxis label="Ndeshjet" /></xAxis>
                <yAxis><NumberAxis label="Pikët" /></yAxis>
            </LineChart>
            
            <PieChart title="Shpërndarja e Shënimeve" prefHeight="350" />
        </HBox>
    </VBox>
</ScrollPane>
