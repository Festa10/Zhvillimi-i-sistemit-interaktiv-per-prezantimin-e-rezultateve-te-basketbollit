<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.MatchController"
            style="-fx-background-color: #f4f6f9;">

    <!-- TOP TITLE -->
    <top>

        <VBox alignment="CENTER" spacing="10">

            <padding>
                <Insets top="20" bottom="10"/>
            </padding>

            <Label text="Basketball Match Management"
                   style="-fx-font-size: 28px;
                          -fx-font-weight: bold;
                          -fx-text-fill: #1e293b;"/>

            <Label text="Manage Matches, Teams and Results"
                   style="-fx-font-size: 14px;
                          -fx-text-fill: #64748b;"/>

        </VBox>

    </top>

    <!-- CENTER CONTENT -->
    <center>

        <VBox spacing="20" alignment="TOP_CENTER">

            <padding>
                <Insets top="10" right="25" bottom="25" left="25"/>
            </padding>

            <!-- FORM CARD -->
            <VBox spacing="15"
                  prefWidth="700"
                  style="-fx-background-color: white;
                         -fx-background-radius: 12;
                         -fx-padding: 20;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10,0,0,3);">

                <Label text="Add New Match"
                       style="-fx-font-size: 20px;
                              -fx-font-weight: bold;"/>

                <GridPane hgap="15" vgap="15">

                    <!-- HOME TEAM -->
                    <Label text="Home Team:"
                           GridPane.rowIndex="0"
                           GridPane.columnIndex="0"/>

                    <ComboBox fx:id="homeTeamCombo"
                              promptText="Select Home Team"
                              prefWidth="220"
                              GridPane.rowIndex="0"
                              GridPane.columnIndex="1"/>

                    <!-- AWAY TEAM -->
                    <Label text="Away Team:"
                           GridPane.rowIndex="1"
                           GridPane.columnIndex="0"/>

                    <ComboBox fx:id="awayTeamCombo"
                              promptText="Select Away Team"
                              prefWidth="220"
                              GridPane.rowIndex="1"
                              GridPane.columnIndex="1"/>

                    <!-- SCORE -->
                    <Label text="Score:"
                           GridPane.rowIndex="2"
                           GridPane.columnIndex="0"/>

                    <TextField fx:id="scoreField"
                               promptText="Example: 89 - 76"
                               prefWidth="220"
                               GridPane.rowIndex="2"
                               GridPane.columnIndex="1"/>

                    <!-- MATCH TYPE -->
                    <Label text="Match Type:"
                           GridPane.rowIndex="3"
                           GridPane.columnIndex="0"/>

                    <HBox spacing="20"
                          GridPane.rowIndex="3"
                          GridPane.columnIndex="1">

                        <RadioButton fx:id="ligaRadio"
                                     text="Liga"/>

                        <RadioButton fx:id="kupaRadio"
                                     text="Kupa"/>

                    </HBox>

                    <!-- FINISHED -->
                    <Label text="Status:"
                           GridPane.rowIndex="4"
                           GridPane.columnIndex="0"/>

                    <CheckBox fx:id="finishedCheckBox"
                              text="Match Finished"
                              GridPane.rowIndex="4"
                              GridPane.columnIndex="1"/>

                </GridPane>

                <!-- BUTTONS -->
                <HBox spacing="15" alignment="CENTER">

                    <Button text="Add Match"
                            onAction="#saveMatch"
                            prefWidth="130"
                            style="-fx-background-color: #2563eb;
                                   -fx-text-fill: white;
                                   -fx-font-weight: bold;
                                   -fx-background-radius: 8;"/>

                    <Button text="Edit Match"
                            onAction="#editMatch"
                            prefWidth="130"
                            style="-fx-background-color: #f59e0b;
                                   -fx-text-fill: white;
                                   -fx-font-weight: bold;
                                   -fx-background-radius: 8;"/>

                    <Button text="Delete Match"
                            onAction="#deleteMatch"
                            prefWidth="130"
                            style="-fx-background-color: #dc2626;
                                   -fx-text-fill: white;
                                   -fx-font-weight: bold;
                                   -fx-background-radius: 8;"/>

                    <Button text="Clear"
                            onAction="#clearFields"
                            prefWidth="130"
                            style="-fx-background-color: #64748b;
                                   -fx-text-fill: white;
                                   -fx-font-weight: bold;
                                   -fx-background-radius: 8;"/>

                </HBox>

            </VBox>

            <!-- SEARCH -->
            <HBox spacing="10"
                  alignment="CENTER_LEFT"
                  prefWidth="700">

                <Label text="Search Match:"
                       style="-fx-font-weight: bold;"/>

                <TextField fx:id="searchField"
                           promptText="Search by team name..."
                           prefWidth="250"/>

            </HBox>

            <!-- TABLE -->
            <TableView fx:id="matchTable"
                       prefWidth="700"
                       prefHeight="300"
                       style="-fx-background-radius: 10;">

                <columns>

                    <TableColumn fx:id="homeColumn"
                                 text="Home Team"
                                 prefWidth="140"/>

                    <TableColumn fx:id="awayColumn"
                                 text="Away Team"
                                 prefWidth="140"/>

                    <TableColumn fx:id="scoreColumn"
                                 text="Score"
                                 prefWidth="120"/>

                    <TableColumn fx:id="typeColumn"
                                 text="Match Type"
                                 prefWidth="120"/>

                    <TableColumn fx:id="finishedColumn"
                                 text="Finished"
                                 prefWidth="120"/>

                </columns>

            </TableView>

        </VBox>

    </center>

</BorderPane>