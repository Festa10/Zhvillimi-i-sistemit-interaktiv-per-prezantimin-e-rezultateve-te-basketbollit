<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>

<VBox spacing="20" style="-fx-padding: 40; -fx-background-color: #1a1d23;" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <Label text="Ndihma / Help" style="-fx-text-fill: #f36f21; -fx-font-size: 24; -fx-font-weight: bold;" />
      <Separator opacity="0.2" />
      <TextFlow lineSpacing="5">
         <children>
            <Text fill="WHITE" text="Si të përdorni aplikacionin:&#10;" style="-fx-font-weight: bold;" />
            <Text fill="#b0b3b8" text="1. Navigoni në Dashboard për të parë statistikat e fundit.&#10;" />
            <Text fill="#b0b3b8" text="2. Përdorni menunë 'Gjuha' për të ndërruar në Anglisht.&#10;" />
            <Text fill="#b0b3b8" text="3. Përdorni 'Shortcuts' (Alt + F) për qasje të shpejtë." />
         </children>
      </TextFlow>
      <Button text="Kthehu mbrapa" styleClass="nav-button-active" onAction="#handleShowDashboard" />
   </children>
</VBox>
