<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.MatchController"
            style="-fx-background-color: #f4f6f9;">

    <!-- TOP -->
    <top>
        <VBox alignment="CENTER" spacing="10">
            <padding>
                <Insets top="20" bottom="10"/>
            </padding>

            <Label text="Basketball Match Management"
                   style="-fx-font-size: 28px;
                          -fx-font-weight: bold;
                          -fx-text-fill: #1e293b;"/>

            <Label text="Manage Matches, Teams and Results"
                   style="-fx-font-size: 14px;
                          -fx-text-fill: #64748b;"/>
        </VBox>
    </top>

    <!-- CENTER -->
    <center>
        <VBox spacing="20" alignment="TOP_CENTER">

            <padding>
                <Insets top="10" right="25" bottom="25" left="25"/>
            </padding>

            <!-- FORM -->
            <VBox spacing="15"
                  prefWidth="750"
                  style="-fx-background-color: white;
                         -fx-background-radius: 12;
                         -fx-padding: 20;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10,0,0,3);">

                <Label text="Add / Edit Match"
                       style="-fx-font-size: 20px;
                              -fx-font-weight: bold;"/>

                <GridPane hgap="15" vgap="15">

                    <!-- HOME TEAM -->
                    <Label text="Home Team:"
                           GridPane.rowIndex="0"
                           GridPane.columnIndex="0"/>

                    <ComboBox fx:id="homeTeamCombo"
                              promptText="Select Home Team"
                              prefWidth="220"
                              GridPane.rowIndex="0"
                              GridPane.columnIndex="1"/>

                    <!-- AWAY TEAM -->
                    <Label text="Away Team:"
                           GridPane.rowIndex="1"
                           GridPane.columnIndex="0"/>

                    <ComboBox fx:id="awayTeamCombo"
                              promptText="Select Away Team"
                              prefWidth="220"
                              GridPane.rowIndex="1"
                              GridPane.columnIndex="1"/>

                    <!-- HOME SCORE -->
                    <Label text="Home Score:"
                           GridPane.rowIndex="2"
                           GridPane.columnIndex="0"/>

                    <TextField fx:id="homeScoreField"
                               promptText="Home Score"
                               prefWidth="220"
                               GridPane.rowIndex="2"
                               GridPane.columnIndex="1"/>

                    <!-- AWAY SCORE -->
                    <Label text="Away Score:"
                           GridPane.rowIndex="3"
                           GridPane.columnIndex="0"/>

                    <TextField fx:id="awayScoreField"
                               promptText="Away Score"
                               prefWidth="220"
                               GridPane.rowIndex="3"
                               GridPane.columnIndex="1"/>

                    <!-- MATCH TYPE -->
                    <Label text="Match Type:"
                           GridPane.rowIndex="4"
                           GridPane.columnIndex="0"/>

                    <HBox spacing="20"
                          GridPane.rowIndex="4"
                          GridPane.columnIndex="1">

                        <RadioButton fx:id="ligaRadio" text="Liga"/>
                        <RadioButton fx:id="kupaRadio" text="Kupa"/>

                    </HBox>

                    <!-- STATUS -->
                    <Label text="Status:"
                           GridPane.rowIndex="5"
                           GridPane.columnIndex="0"/>

                    <CheckBox fx:id="finishedCheckBox"
                              text="Finished"
                              GridPane.rowIndex="5"
                              GridPane.columnIndex="1"/>

                    <!-- REFEREE -->
                    <Label text="Referee:"
                           GridPane.rowIndex="6"
                           GridPane.columnIndex="0"/>

                    <TextField fx:id="refereeField"
                               promptText="Referee name"
                               GridPane.rowIndex="6"
                               GridPane.columnIndex="1"/>

                    <!-- STADIUM -->
                    <Label text="Stadium:"
                           GridPane.rowIndex="7"
                           GridPane.columnIndex="0"/>

                    <TextField fx:id="stadiumField"
                               promptText="Stadium name"
                               GridPane.rowIndex="7"
                               GridPane.columnIndex="1"/>

                </GridPane>

                <!-- BUTTONS -->
                <HBox spacing="15" alignment="CENTER">

                    <Button text="Add Match"
                            onAction="#saveMatch"
                            prefWidth="130"
                            style="-fx-background-color: #2563eb;
                                   -fx-text-fill: white;
                                   -fx-font-weight: bold;
                                   -fx-background-radius: 8;"/>

                    <Button text="Edit Match"
                            onAction="#editMatch"
                            prefWidth="130"
                            style="-fx-background-color: #f59e0b;
                                   -fx-text-fill: white;
                                   -fx-font-weight: bold;
                                   -fx-background-radius: 8;"/>

                    <Button text="Delete Match"
                            onAction="#deleteMatch"
                            prefWidth="130"
                            style="-fx-background-color: #dc2626;
                                   -fx-text-fill: white;
                                   -fx-font-weight: bold;
                                   -fx-background-radius: 8;"/>

                    <Button text="Clear"
                            onAction="#clearFields"
                            prefWidth="130"
                            style="-fx-background-color: #64748b;
                                   -fx-text-fill: white;
                                   -fx-font-weight: bold;
                                   -fx-background-radius: 8;"/>

                </HBox>

            </VBox>

            <!-- SEARCH -->
            <HBox spacing="10"
                  alignment="CENTER_LEFT"
                  prefWidth="750">

                <Label text="Search:"
                       style="-fx-font-weight: bold;"/>

                <TextField fx:id="searchField"
                           promptText="Search match by team..."
                           prefWidth="250"/>

            </HBox>

            <!-- TABLE -->
            <TableView fx:id="matchTable"
                       prefWidth="750"
                       prefHeight="320"
                       style="-fx-background-radius: 10;">

                <columns>

                    <TableColumn fx:id="homeColumn"
                                 text="Home Team"/>

                    <TableColumn fx:id="awayColumn"
                                 text="Away Team"/>

                    <TableColumn fx:id="scoreColumn"
                                 text="Score"/>

                    <TableColumn fx:id="winnerColumn"
                                 text="Winner"/>

                    <TableColumn fx:id="typeColumn"
                                 text="Type"/>

                    <TableColumn fx:id="finishedColumn"
                                 text="Finished"/>

                </columns>

            </TableView>

        </VBox>
    </center>

</BorderPane>